@article{thiourea,
title = {{Thermal properties of the nonlinear optical crystal zinc tris (thiourea) sulphate}},
author = {Kerkoc, P. and Venkataramanan, V. and Lochran, S. and Bailey, R. T. and Cruickshank, F. R. and Pugh, D. and Sherwood, J. N. and Moseley, R. and Goeta, A. E. and Lehmann, C. W. and Howard, J. A. K.},
language = {eng},
issn = {0021-8979},
doi = {10.1063/1.363791},
publisher = {AIP Publishing},
address = {New York, NY},
year = {1996},
date = {1996-12-15},
abstract = {{The heat capacity of crystalline zinc tris (thiourea) sulphate, has been measured in the range from 220 to 500 K by differential scanning calorimetry, and was found to obey the relationship Cp(T){\textequals}2.76$\times$10{\textless}sup{\textgreater}{\textminus}3{\textless}/sup{\textgreater} T+0.366 J g{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}. Thermal expansion data have been measured in the range from 150 to 473 K. From these data, the principal thermal expansion coefficients were found to be $\alpha${\textless}sub{\textgreater}1{\textless}/sub{\textgreater}{\textequals}6.41$\times$10{\textless}sup{\textgreater}{\textminus}5{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}, $\alpha${\textless}sub{\textgreater}2{\textless}/sub{\textgreater}{\textequals}4.52$\times$10{\textless}sup{\textgreater}{\textminus}5{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}, and $\alpha${\textless}sub{\textgreater}3{\textless}/sub{\textgreater}{\textequals}{\textminus}4.32$\times$10{\textless}sup{\textgreater}{\textminus}6{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}. The thermal conductivity tensor of this orthorhombic crystal was calculated from values of the thermal diffusivity in the directions normal to the (100), (010), and (001) crystal planes by the laser flash method. The thermal conductivity coefficients at 295 K are k{\textless}sub{\textgreater}{\textless}/sub{\textgreater}{\textequals}0.27 W m{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}, k{\textless}sub{\textgreater}2{\textless}/sub{\textgreater}{\textequals}0.34 W m{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}, and k{\textless}sub{\textgreater}{\textless}/sub{\textgreater}{\textequals}0.54 W m{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater} K{\textless}sup{\textgreater}{\textminus}1{\textless}/sup{\textgreater}.{\textless}br{\textgreater}REFERENCES}},
journal = {{Journal of Applied Physics}},
volume = {80},
number = {12},
pages = {6666--6669},
}
